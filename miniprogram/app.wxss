page {
  min-height: 100vh;
  background: #faf5ff;
  color: #1e293b;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 56rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #eee7f5;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(88, 28, 135, 0.06);
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button {
  color: #ffffff;
  background: linear-gradient(135deg, #a855f7 0%, #c084fc 100%);
  box-shadow: 0 10rpx 24rpx rgba(168, 85, 247, 0.22);
}

.secondary-button {
  color: #39465e;
  background: #eef2f6;
}

.ghost-button {
  color: #9333ea;
  background: #f3e8ff;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.section-desc {
  margin-top: -10rpx;
  margin-bottom: 24rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.page-heading {
  margin-bottom: 26rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.6;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #7e22ce;
  background: #f3e8ff;
  font-size: 24rpx;
  font-weight: 600;
}

.muted {
  color: #667085;
}

.link-text {
  color: #9333ea;
  word-break: break-all;
}
