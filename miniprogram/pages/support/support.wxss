.privacy-note {
  padding: 26rpx;
  background: #fff8ec;
  border-color: #f6d49b;
}

.privacy-title {
  color: #925600;
  font-size: 28rpx;
  font-weight: 750;
}

.privacy-text {
  margin-top: 10rpx;
  color: #6f4a14;
  font-size: 25rpx;
  line-height: 1.6;
}

.form-card,
.summary-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f5;
}

.field:first-child {
  padding-top: 0;
}

.field-label {
  margin-bottom: 14rpx;
  color: #344054;
  font-size: 27rpx;
  font-weight: 700;
}

.field-label text {
  margin-left: 8rpx;
  color: #98a2b3;
  font-size: 23rpx;
  font-weight: 400;
}

.picker-value,
.field-input {
  min-height: 78rpx;
  color: #1d2939;
  font-size: 28rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value text {
  color: #98a2b3;
  font-size: 38rpx;
}

.field-input {
  height: 78rpx;
}

.field-textarea {
  width: 100%;
  min-height: 210rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  color: #1d2939;
  background: #f7f9fc;
  font-size: 27rpx;
  line-height: 1.6;
}

.word-count {
  margin-top: 10rpx;
  color: #98a2b3;
  font-size: 23rpx;
  text-align: right;
}

.diagnosis-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  color: #475467;
  background: #faf5ff;
  font-size: 24rpx;
}

.redo {
  flex: none;
  color: #9333ea;
  font-weight: 700;
}

.generate-button {
  width: 100%;
  margin-top: 26rpx;
}

.summary-text {
  display: block;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 12rpx;
  color: #344054;
  background: #f7f9fc;
  font-size: 26rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.summary-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.direct-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 28rpx;
}

.direct-title {
  font-size: 28rpx;
  font-weight: 700;
}

.direct-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.contact-link {
  min-width: 150rpx;
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 10rpx;
  color: #9333ea;
  background: #f3e8ff;
  font-size: 25rpx;
  font-weight: 700;
}

.clear-form {
  width: 100%;
  margin-top: 20rpx;
  color: #667085;
  font-size: 26rpx;
  background: transparent;
}
