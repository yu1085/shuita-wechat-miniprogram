.support-card,
.info-card {
  padding: 32rpx;
}

.support-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  border-radius: 30rpx;
  background: #eef2f6;
}

.support-title {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.support-desc {
  margin: 16rpx 0 28rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.65;
}

.contact-button {
  width: 100%;
  margin-bottom: 18rpx;
}

.secondary-button {
  width: 100%;
}

.info-card {
  margin-top: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  color: #344054;
  font-size: 29rpx;
  border-top: 1rpx solid #edf0f5;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  flex: none;
  border-radius: 50%;
  background: #19b36b;
}
