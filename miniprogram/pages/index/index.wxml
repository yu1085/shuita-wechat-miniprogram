<view class="page">
  <view class="hero panel">
    <image class="logo" src="/assets/logo.png" mode="aspectFill" />
    <view class="hero-copy">
      <view class="eyebrow">官方入口</view>
      <view class="title">水獭智聊</view>
      <view class="subtitle">查看官方服务入口、使用指引和客服反馈入口。</view>
    </view>
  </view>

  <view class="notice panel">
    <view class="notice-title">微信内访问提示</view>
    <view class="notice-text">如需查看完整服务说明，请复制官方页面链接，在系统浏览器中打开。</view>
  </view>

  <view class="actions">
    <button class="primary-button" bindtap="copyOfficialUrl">复制官方页面链接</button>
  </view>

  <view class="quick panel">
    <view class="section-title">常用服务</view>
    <view class="service-list">
      <view class="service-item" bindtap="goInstall">
        <view>
          <view class="service-title">使用指引</view>
          <view class="service-desc">查看系统浏览器打开官方页面的说明</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="service-item" bindtap="goSupport">
        <view>
          <view class="service-title">联系客服</view>
          <view class="service-desc">登录、认证、账号和使用问题反馈</view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="url-card panel">
    <view class="section-title">官方服务地址</view>
    <text class="link-text">{{officialUrl}}</text>
  </view>
</view>
