<view class="page">
  <view class="hero panel">
    <image class="logo" src="/assets/logo.png" mode="aspectFill" />
    <view class="hero-copy">
      <view class="eyebrow">官方服务助手</view>
      <view class="title">水獭智聊</view>
      <view class="subtitle">查询帮助、排查问题并整理反馈信息。</view>
    </view>
  </view>

  <view class="notice panel">
    <view class="notice-title">无需登录即可使用</view>
    <view class="notice-text">所有排查和反馈内容均在本机处理，不会由小程序自动上传。</view>
  </view>

  <view class="service-grid">
    <view
      class="service-card panel"
      wx:for="{{services}}"
      wx:key="title"
      data-url="{{item.url}}"
      bindtap="openService"
    >
      <view class="service-icon">{{item.icon}}</view>
      <view class="service-title">{{item.title}}</view>
      <view class="service-desc">{{item.desc}}</view>
      <view class="service-link">立即使用 <text>›</text></view>
    </view>
  </view>

  <button class="primary-button diagnose-button" bindtap="startDiagnose">开始账号问题自助排查</button>

  <view class="quick panel">
    <view class="section-title">常见问题</view>
    <view class="question-list">
      <view
        class="question-item"
        wx:for="{{commonQuestions}}"
        wx:key="title"
        data-query="{{item.query}}"
        bindtap="searchQuestion"
      >
        <text>{{item.title}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
