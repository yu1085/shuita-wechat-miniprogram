.hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #ffffff 0%, #faf5ff 64%, #f3e8ff 100%);
  border-color: #e9d5ff;
}

.hero::after {
  position: absolute;
  right: -64rpx;
  bottom: -82rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232, 121, 249, 0.32) 0%, rgba(168, 85, 247, 0) 70%);
  content: "";
}

.logo {
  position: relative;
  z-index: 1;
  width: 128rpx;
  height: 128rpx;
  flex: none;
  border-radius: 28rpx;
  background: #f3e8ff;
  box-shadow: 0 8rpx 22rpx rgba(168, 85, 247, 0.18);
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #a855f7;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.55;
}

.notice {
  margin-top: 22rpx;
  padding: 28rpx;
  background: #faf5ff;
  border-color: #e9d5ff;
}

.notice-title {
  color: #7e22ce;
  font-size: 30rpx;
  font-weight: 700;
}

.notice-text {
  margin-top: 12rpx;
  color: #6b21a8;
  font-size: 27rpx;
  line-height: 1.65;
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.service-card {
  position: relative;
  padding: 30rpx;
}

.service-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #a855f7 0%, #e879f9 100%);
  box-shadow: 0 8rpx 18rpx rgba(168, 85, 247, 0.18);
  font-size: 28rpx;
  font-weight: 800;
}

.service-link {
  margin-top: 20rpx;
  color: #9333ea;
  font-size: 25rpx;
  font-weight: 700;
}

.service-link text {
  margin-left: 6rpx;
  font-size: 34rpx;
}

.service-title {
  font-size: 31rpx;
  font-weight: 700;
}

.service-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.diagnose-button {
  width: 100%;
  margin-top: 24rpx;
}

.quick {
  margin-top: 24rpx;
  padding: 30rpx;
}

.question-list {
  border-top: 1rpx solid #edf0f5;
}

.question-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  color: #344054;
  font-size: 28rpx;
  border-bottom: 1rpx solid #edf0f5;
}

.question-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #98a2b3;
  font-size: 52rpx;
  line-height: 1;
}
