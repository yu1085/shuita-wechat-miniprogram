.hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx;
}

.logo {
  width: 128rpx;
  height: 128rpx;
  flex: none;
  border-radius: 28rpx;
  background: #eef2f6;
}

.hero-copy {
  min-width: 0;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #19a866;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.55;
}

.notice {
  margin-top: 22rpx;
  padding: 28rpx;
  background: #fff8ec;
  border-color: #f6d49b;
}

.notice-title {
  color: #a05a00;
  font-size: 30rpx;
  font-weight: 700;
}

.notice-text {
  margin-top: 12rpx;
  color: #6f4a14;
  font-size: 27rpx;
  line-height: 1.65;
}

.actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick,
.url-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.service-list {
  border-top: 1rpx solid #edf0f5;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 128rpx;
  border-bottom: 1rpx solid #edf0f5;
}

.service-item:last-child {
  border-bottom: none;
}

.service-title {
  font-size: 31rpx;
  font-weight: 700;
}

.service-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
}

.arrow {
  color: #98a2b3;
  font-size: 52rpx;
  line-height: 1;
}

.url-card {
  line-height: 1.6;
}
