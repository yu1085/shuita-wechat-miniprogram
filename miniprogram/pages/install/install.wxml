<view class="page">
  <view class="panel guide">
    <view class="section-title">使用指引</view>
    <view class="step" wx:for="{{steps}}" wx:key="*this">
      <view class="step-index">{{index + 1}}</view>
      <view class="step-text">{{item}}</view>
    </view>
  </view>

  <view class="panel warning">
    <view class="warning-title">反馈说明</view>
    <view class="warning-text">反馈时建议提供注册手机号或用户 ID、问题发生时间、相关页面截图和简要问题描述。</view>
  </view>

  <view class="actions">
    <button class="primary-button" bindtap="goSupport">联系客服</button>
  </view>
</view>
